    // ═══ Progress / Game Tab Helpers ═══

    private void LoadProgressData()
    {
        // Completed task count
        _completedTaskCount = _userTasks.Count(t => t.Status == SkillTaskStatus.Completed);

        // Calculate total XP from ratings received
        _totalXp = _ratings.Sum(r => r.XpAwarded);

        // Build skill progress from ratings grouped by category
        _skillProgressList = _ratings
            .Where(r => r.Category.HasValue)
            .GroupBy(r => r.Category!.Value)
            .Select(g => new UserSkillProgress
            {
                Category = g.Key,
                TotalXp = g.Sum(r => r.XpAwarded),
                CurrentTier = GetTierEnum(g.Sum(r => r.XpAwarded))
            })
            .OrderByDescending(sp => sp.TotalXp)
            .ToList();

        // If no XP from ratings, fallback: estimate from badges
        if (_totalXp == 0 && _badges.Any())
        {
            foreach (var badge in _badges)
            {
                var existing = _skillProgressList.FirstOrDefault(s => s.Category == badge.Category);
                if (existing == null)
                {
                    int estimatedXp = badge.Tier switch
                    {
                        BadgeTier.Newbie => 25,
                        BadgeTier.Skilled => 75,
                        BadgeTier.Advanced => 300,
                        BadgeTier.Expert => 800,
                        BadgeTier.Master => 1800,
                        _ => 0
                    };
                    _skillProgressList.Add(new UserSkillProgress { Category = badge.Category, TotalXp = estimatedXp, CurrentTier = badge.Tier });
                    _totalXp += estimatedXp;
                }
            }
        }

        // Calculate level (every 100 XP = 1 level)
        _userLevel = Math.Max(1, _totalXp / 100 + 1);
        _nextLevelXp = _userLevel * 100;
        int prevLevelXp = (_userLevel - 1) * 100;
        _levelProgress = _nextLevelXp > prevLevelXp 
            ? ((double)(_totalXp - prevLevelXp) / (_nextLevelXp - prevLevelXp)) * 100 
            : 100;

        // Simulated streak based on recent completed tasks
        var recentCompleted = _userTasks
            .Where(t => t.CompletedAt.HasValue)
            .OrderByDescending(t => t.CompletedAt)
            .ToList();
        _userStreak = 0;
        var checkDate = DateTime.UtcNow.Date;
        foreach (var task in recentCompleted)
        {
            if (task.CompletedAt!.Value.Date == checkDate || task.CompletedAt.Value.Date == checkDate.AddDays(-1))
            {
                _userStreak++;
                checkDate = task.CompletedAt.Value.Date.AddDays(-1);
            }
            else break;
        }
        if (_userStreak == 0 && recentCompleted.Any()) _userStreak = 1; // At least 1 if they have completed tasks

        // Build achievements from real data
        _achievements = new()
        {
            (1, "First Task", "Complete your first task", "🎯", _completedTaskCount >= 1, Math.Min(_completedTaskCount, 1), 1),
            (2, "Helping Hand", "Complete 10 tasks", "🤝", _completedTaskCount >= 10, Math.Min(_completedTaskCount, 10), 10),
            (3, "Streak Starter", "Achieve a 7-day streak", "🔥", _userStreak >= 7, Math.Min(_userStreak, 7), 7),
            (4, "XP Hunter", "Earn 500 XP total", "⚡", _totalXp >= 500, Math.Min(_totalXp, 500), 500),
            (5, "Multi-skilled", "Earn badges in 3 categories", "🌟", _badges.Count >= 3, Math.Min(_badges.Count, 3), 3),
            (6, "Task Master", "Complete 50 tasks", "👑", _completedTaskCount >= 50, Math.Min(_completedTaskCount, 50), 50),
            (7, "Legend", "Reach Master tier (1500 XP)", "🏆", _totalXp >= 1500, Math.Min(_totalXp, 1500), 1500),
            (8, "Marathon", "Maintain a 30-day streak", "🏃", _userStreak >= 30, Math.Min(_userStreak, 30), 30),
        };

        // Build recent XP activity from ratings
        _xpActivity = _ratings
            .OrderByDescending(r => r.CreatedAt)
            .Take(8)
            .Select(r => (
                type: "task",
                desc: $"Rated {r.Stars}★ for task #{r.TaskId}",
                xp: r.XpAwarded,
                time: GetRelativeTime(r.CreatedAt),
                category: r.Category?.ToString() ?? ""
            ))
            .ToList();
    }

    private BadgeTier GetTierEnum(int xp)
    {
        if (xp >= 1500) return BadgeTier.Master;
        if (xp >= 600) return BadgeTier.Expert;
        if (xp >= 200) return BadgeTier.Advanced;
        if (xp >= 50) return BadgeTier.Skilled;
        return BadgeTier.Newbie;
    }

    private (string name, int minXp, string color) GetTierInfo(int xp)
    {
        if (xp >= 1500) return ("Master", 1500, "#f6c445");
        if (xp >= 600) return ("Expert", 600, "#e45f2b");
        if (xp >= 200) return ("Advanced", 200, "#4a75b0");
        if (xp >= 50) return ("Skilled", 50, "#a0e548");
        return ("Newbie", 0, "#9E9E9E");
    }

    private (string name, int minXp, string color)? GetNextTierInfo(int xp)
    {
        if (xp < 50) return ("Skilled", 50, "#a0e548");
        if (xp < 200) return ("Advanced", 200, "#4a75b0");
        if (xp < 600) return ("Expert", 600, "#e45f2b");
        if (xp < 1500) return ("Master", 1500, "#f6c445");
        return null;
    }

