@page "/classroom"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using System
@using System.Linq
@inject ICourseService CourseService
@inject NavigationManager Navigation
@inject CommandBarState CmdState

<PageTitle>The Classroom - Skill Share Map</PageTitle>

<div class="cr-page">

    <!-- ── Hero ── -->
    <div class="cr-hero">
        <div class="cr-hero__accent"></div>
        <div class="cr-hero__content">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                     Icon="@Icons.Material.Filled.AutoStories" Class="mb-2">
                Learning Hub
            </MudChip>
            <h1 class="cr-hero__title">The Classroom</h1>
            <p class="cr-hero__sub">Discover courses, workshops, and learning resources to enhance your skills and boost your career.</p>
        </div>
    </div>

    <!-- ── Search + Chips ── -->
    <div class="cr-toolbar">
        <div class="cr-search">
            <MudTextField @bind-Value="_searchQuery"
                          Placeholder="Search courses, workshops, skills..."
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Margin="Margin.Dense"
                          Immediate="true"
                          TextChanged="OnSearchChanged"
                          Class="cr-search__field" />
        </div>
        <div class="cr-chips">
            <MudChip T="string"
                     Color="@(_selectedCategory == null ? Color.Primary : Color.Default)"
                     Variant="@(_selectedCategory == null ? Variant.Filled : Variant.Outlined)"
                     OnClick="() => SetCategory(null)"
                     Class="cr-chip">
                All
            </MudChip>
            @foreach (var category in Enum.GetValues<TaskCategory>())
            {
                <MudChip T="string"
                         Color="@(_selectedCategory == category ? Color.Primary : Color.Default)"
                         Variant="@(_selectedCategory == category ? Variant.Filled : Variant.Outlined)"
                         OnClick="() => SetCategory(category)"
                         Class="cr-chip">
                    @GetCategoryName(category)
                </MudChip>
            }
        </div>
    </div>

    <!-- ── AI Coach Card ── -->
    <div class="cr-ai-banner">
        <div class="cr-ai-banner__icon">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Style="font-size:2rem; color:#fff;" />
        </div>
        <div class="cr-ai-banner__body">
            <h3>AI Study Coach</h3>
            <p>Get personalised guidance, practice problems, and real-time feedback — tailored to your skill level.</p>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@(() => CmdState.Open("Recommend tasks for me"))"
                   StartIcon="@Icons.Material.Filled.SmartToy"
                   Class="cr-ai-banner__btn">
            Ask Sage
        </MudButton>
    </div>

    <!-- ── Loading ── -->
    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center" style="min-height: 300px;">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_filteredCourses.Any())
    {
        <!-- ── Section Header ── -->
        <div class="cr-section-head">
            <MudText Typo="Typo.h6" Style="font-weight:700;">Browse Courses</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_filteredCourses.Count courses</MudText>
        </div>

        <!-- ── Cards Grid ── -->
        <div class="cr-grid">
            @foreach (var course in _filteredCourses)
            {
                <MudPaper Elevation="0" Class="cr-card" @onclick="() => NavigateToCourse(course.Id)">

                    <!-- Thumbnail -->
                    <div class="cr-card__thumb" style="background: linear-gradient(135deg, @GetCategoryGradientStart(course.Category), @GetCategoryGradientEnd(course.Category));">
                        <MudIcon Icon="@GetCategoryIcon(course.Category)" Style="font-size:2.2rem; color:rgba(255,255,255,0.85);" />
                        <MudChip T="string" Size="Size.Small"
                                 Color="@GetDifficultyColor(course.Difficulty)"
                                 Variant="Variant.Filled"
                                 Class="cr-card__level">
                            @course.Difficulty
                        </MudChip>
                    </div>

                    <!-- Body -->
                    <div class="cr-card__body">
                        <MudText Typo="Typo.overline" Color="Color.Primary" Style="font-weight:700; letter-spacing:0.06em;">
                            @GetCategoryName(course.Category)
                        </MudText>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700; line-height:1.35; margin:4px 0 6px;">
                            @course.Title
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="cr-card__desc">
                            @course.Description
                        </MudText>
                    </div>

                    <!-- Meta -->
                    <div class="cr-card__meta">
                        <span class="cr-card__meta-item">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                            @(course.InstructorName ?? "TBA")
                        </span>
                        <span class="cr-card__meta-item">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Secondary" />
                            @(course.Duration ?? "—")
                        </span>
                        <span class="cr-card__meta-item">
                            <MudIcon Icon="@GetTypeIcon(course.Type)" Size="Size.Small" Color="Color.Secondary" />
                            @GetTypeName(course.Type)
                        </span>
                    </div>

                    <!-- Footer -->
                    <div class="cr-card__footer">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Size="Size.Small">
                            View Details
                        </MudButton>
                        @if (!string.IsNullOrEmpty(course.ExternalUrl))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Launch"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Href="@course.ExternalUrl"
                                           Target="_blank"
                                           @onclick:stopPropagation="true" />
                        }
                    </div>
                </MudPaper>
            }
        </div>
    }
    else
    {
        <!-- ── Empty ── -->
        <MudPaper Elevation="0" Class="cr-empty">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mt-3">No courses found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">Try adjusting your filters or clearing the search.</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ClearFilters">Show All Courses</MudButton>
        </MudPaper>
    }
</div>

@code {
    private List<Course> _courses = new();
    private List<Course> _filteredCourses = new();
    private TaskCategory? _selectedCategory;
    private bool _isLoading = true;
    private string _searchQuery = string.Empty;
    private string _aiQuestion = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();
    }

    private async Task LoadCourses()
    {
        _isLoading = true;
        try
        {
            _courses = await CourseService.GetAllCoursesAsync();
            ApplyFilters();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SetCategory(TaskCategory? category)
    {
        _selectedCategory = category;
        ApplyFilters();
        StateHasChanged();
    }

    private void OnSearchChanged(string value)
    {
        _searchQuery = value ?? string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void ClearFilters()
    {
        _selectedCategory = null;
        _searchQuery = string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void ApplyFilters()
    {
        var query = _courses.AsEnumerable();

        if (_selectedCategory.HasValue)
        {
            query = query.Where(c => c.Category == _selectedCategory.Value);
        }

        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            var q = _searchQuery.ToLower();
            query = query.Where(c =>
                (c.Title?.ToLower().Contains(q) ?? false) ||
                (c.Description?.ToLower().Contains(q) ?? false) ||
                GetCategoryName(c.Category).ToLower().Contains(q));
        }

        _filteredCourses = query.ToList();
    }

    private void NavigateToCourse(int id)
    {
        Navigation.NavigateTo($"/course/{id}");
    }

    // ── Helpers ──

    private string GetCategoryName(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "Study Help",
        TaskCategory.TechHelp => "Tech Help",
        TaskCategory.CreativeDesign => "Creative Design",
        TaskCategory.PhotoVideo => "Photo & Video",
        TaskCategory.WritingEditing => "Writing & Editing",
        TaskCategory.LanguageHelp => "Language Help",
        _ => category.ToString()
    };

    private string GetCategoryIcon(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => Icons.Material.Filled.MenuBook,
        TaskCategory.TechHelp => Icons.Material.Filled.Computer,
        TaskCategory.CreativeDesign => Icons.Material.Filled.Brush,
        TaskCategory.PhotoVideo => Icons.Material.Filled.PhotoCamera,
        TaskCategory.WritingEditing => Icons.Material.Filled.Edit,
        TaskCategory.LanguageHelp => Icons.Material.Filled.Translate,
        _ => Icons.Material.Filled.Category
    };

    private string GetCategoryGradientStart(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "#667eea",
        TaskCategory.TechHelp => "#0ea5e9",
        TaskCategory.CreativeDesign => "#e879a8",
        TaskCategory.PhotoVideo => "#f59e0b",
        TaskCategory.WritingEditing => "#8b5cf6",
        TaskCategory.LanguageHelp => "#34d399",
        _ => "#667eea"
    };

    private string GetCategoryGradientEnd(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "#764ba2",
        TaskCategory.TechHelp => "#2563eb",
        TaskCategory.CreativeDesign => "#c084fc",
        TaskCategory.PhotoVideo => "#ef4444",
        TaskCategory.WritingEditing => "#6366f1",
        TaskCategory.LanguageHelp => "#06b6d4",
        _ => "#764ba2"
    };

    private string GetTypeName(CourseType type) => type switch
    {
        CourseType.OnlineCourse => "Online Course",
        CourseType.Workshop => "Workshop",
        CourseType.WebSeminar => "Web Seminar",
        CourseType.Tutorial => "Tutorial",
        _ => type.ToString()
    };

    private string GetTypeIcon(CourseType type) => type switch
    {
        CourseType.OnlineCourse => Icons.Material.Filled.OndemandVideo,
        CourseType.Workshop => Icons.Material.Filled.Groups,
        CourseType.WebSeminar => Icons.Material.Filled.Videocam,
        CourseType.Tutorial => Icons.Material.Filled.PlayCircle,
        _ => Icons.Material.Filled.School
    };

    private Color GetDifficultyColor(DifficultyLevel difficulty) => difficulty switch
    {
        DifficultyLevel.Beginner => Color.Success,
        DifficultyLevel.Intermediate => Color.Warning,
        DifficultyLevel.Advanced => Color.Error,
        _ => Color.Default
    };
}
