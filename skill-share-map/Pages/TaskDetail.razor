@page "/task/{TaskId:int}"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using SkillShareMap.Shared.Components
@inject ITaskService TaskService
@inject IWalletService WalletService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject UserState UserState

<PageTitle>Task Details</PageTitle>

@if (_task == null)
{
    <div class="d-flex justify-center align-center" style="min-height: 400px;">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <MudPaper Elevation="0" Class="pa-8 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    
                    @if (!string.IsNullOrEmpty(_task.AttachmentUrl))
                    {
                        <MudImage Src="@_task.AttachmentUrl" Alt="@_task.Title" Height="300" ObjectFit="ObjectFit.Cover" Class="rounded-xl mb-6" Style="width: 100%;" />
                    }

                    <div class="d-flex justify-space-between align-start mb-4">
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1B1B1B; line-height: 1.2;" Class="mb-3">@_task.Title</MudText>
                            <MudChip T="string" Variant="Variant.Text" Color="GetStatusColor(_task.Status)" Size="Size.Small" Class="fw-bold">@_task.Status</MudChip>
                        </div>
                        <div class="pa-2 rounded-circle" style="background-color: #F5F5F5;">
                            <CategoryIcon Category="_task.Category" IconSize="Size.Large" />
                        </div>
                    </div>

                    <MudDivider Class="my-6" />

                    <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700; color: #1B1B1B;">Posted by</MudText>
                    <div class="d-flex align-center mb-6 pa-4 rounded-xl" style="background-color: #F8F9FA;">
                        <MudAvatar Color="Color.Primary" Class="mr-4" Size="Size.Medium">
                            @_task.Creator?.Username?.Substring(0, 1).ToUpper()
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #1B1B1B;">@_task.Creator?.Username</MudText>
                            @if (_task.Creator != null)
                            {
                                <StarRating Rating="_task.Creator.ReputationLevel" ShowRating="true" />
                            }
                        </div>
                    </div>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">@(_task.NegotiatedPrice.HasValue ? "Agreed Price" : "Budget")</MudText>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1B1B1B;">
                                $@(_task.NegotiatedPrice ?? _task.Budget)
                            </MudText>
                        </MudItem>
                        @if (_task.Deadline.HasValue)
                        {
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">Deadline</MudText>
                                <MudText Typo="Typo.body1" Style="color: #1B1B1B;">@_task.Deadline.Value.ToString("MMM dd, yyyy")</MudText>
                            </MudItem>
                        }
                    </MudGrid>

                    <div class="mb-6">
                        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 700; color: #1B1B1B;">Description</MudText>
                        <MudText Typo="Typo.body1" Style="color: #4a4a4a; line-height: 1.6;">@_task.Description</MudText>
                    </div>

                    <MudDivider Class="my-6" />

                    @if (_isCreator)
                    {
                        @if (_task.Status == SkillTaskStatus.Open)
                        {
                             <MudText Typo="Typo.h6" Class="mb-4">Applications Received (@(_task.Applications?.Count ?? 0))</MudText>
                             
                             @if (_task.Applications == null || !_task.Applications.Any())
                             {
                                 <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="rounded-lg">No one has applied for this task yet.</MudAlert>
                             }
                             else
                             {
                                 <MudList T="object" Clickable="false" DisablePadding="true">
                                     @foreach (var app in _task.Applications.Where(a => a.Status == ApplicationStatus.Pending))
                                     {
                                         <MudPaper Elevation="0" Class="pa-4 mb-3 rounded-lg" Style="border: 1px solid #e0e0e0;">
                                             <div class="d-flex justify-space-between align-center">
                                                 <div>
                                                     <div class="d-flex align-center mb-1">
                                                         <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@app.Applicant?.Username</MudText>
                                                         <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-2" Variant="Variant.Text">Bid: $@app.ProposedPrice</MudChip>
                                                     </div>
                                                     <MudText Typo="Typo.body2" Color="Color.Secondary">"@app.Message"</MudText>
                                                 </div>
                                                 <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => AcceptApplication(app.Id))">Accept</MudButton>
                                             </div>
                                         </MudPaper>
                                     }
                                 </MudList>
                             }
                             
                             <div class="mt-4">
                                 <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Cancel" OnClick="CancelTask">Cancel Task</MudButton>
                                 <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Href="@($"/task/{_task.Id}/edit")" Class="ml-2">Edit</MudButton>
                             </div>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingDeposit)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">Waiting for system to process deposit...</MudAlert>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingCompletion)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">Helper marked as done. Please confirm.</MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="ConfirmTaskComplete">Confirm & Pay</MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.Completed)
                        {
                            <MudAlert Severity="Severity.Success">Task Completed!</MudAlert>
                            @if (_task.Rating == null) {
                                <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="OpenRatingDialog" Class="mt-2">Rate Helper</MudButton>
                            }
                        }
                        else if (_task.Status == SkillTaskStatus.Cancelled)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="RepublishTask">Republish</MudButton>
                        }
                    }
                    
                    else
                    {
                        @if (_task.Status == SkillTaskStatus.Open)
                        {
                            var myApp = _task.Applications?.FirstOrDefault(a => a.ApplicantId == _currentUserId);
                            
                            @if (myApp != null)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="rounded-lg">
                                    You applied for this task. Status: <b>@myApp.Status</b>
                                </MudAlert>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-3">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat" 
                                           Href="@($"/chat/{_task.CreatorId}?taskId={_task.Id}")" 
                                           Style="border-radius: 12px; font-weight: 600;">
                                        Open Chat
                                    </MudButton>

                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenApplicationDialog" 
                                           StartIcon="@Icons.Material.Filled.Send"
                                           Style="background-color: #1B1B1B; color: white; border-radius: 12px; font-weight: 700; padding: 8px 24px; flex-grow: 1;">
                                        Apply for Task
                                    </MudButton>

                                    <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Report" 
                                           OnClick="ReportTask" Style="border-radius: 12px;">
                                        Report
                                    </MudButton>
                                </div>
                            }
                        }
                        else if (_isHelper)
                        {
                             @if (_task.Status == SkillTaskStatus.Assigned || _task.Status == SkillTaskStatus.PendingDeposit)
                             {
                                 <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="MarkTaskDone" FullWidth="true" Size="Size.Large">Mark as Done</MudButton>
                             }
                             else if (_task.Status == SkillTaskStatus.PendingCompletion)
                             {
                                 <MudAlert Severity="Severity.Info">Waiting for creator confirmation.</MudAlert>
                             }
                             else if (_task.Status == SkillTaskStatus.Completed)
                             {
                                 <MudAlert Severity="Severity.Success">Task Completed! Payment received.</MudAlert>
                             }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning">This task is currently assigned to another user.</MudAlert>
                        }
                    }

                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                 <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Error" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;">Location</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="mb-4" Style="color: #4a4a4a;">@_task.LocationAddress</MudText>
                    <div class="rounded-xl overflow-hidden" style="border: 1px solid #e0e0e0;">
                        @if (_task.Latitude.HasValue && _task.Longitude.HasValue)
                        {
                            <MapComponent @ref="_miniMap" MapId="taskMap" Height="250px" InitialLat="@_task.Latitude.Value" InitialLng="@_task.Longitude.Value" InitialZoom="15" />
                        }
                        else
                        {
                            <div class="d-flex align-center justify-center" style="height: 200px; background-color: #f5f5f5; color: #999;">No map data</div>
                        }
                    </div>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;" Class="mb-4">Task Info</MudText>
                    
                    <div class="d-flex flex-column gap-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Style="color: #9E9E9E;" Class="mr-3" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Posted</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: 500; color: #1B1B1B;">@_task.CreatedAt.ToString("MMM dd")</MudText>
                            </div>
                        </div>
                        
                        <MudDivider />

                        @if (_task.AssignedTo != null)
                        {
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="color: #9E9E9E;" Class="mr-3" />
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned to</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight: 500; color: #1B1B1B;">@_task.AssignedTo.Username</MudText>
                                </div>
                            </div>
                            <MudDivider />
                        }

                        @if (_task.IsDepositPaid)
                        {
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" Class="mr-3" />
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Security</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-success);">Deposit Paid ($@_task.DepositAmount)</MudText>
                                </div>
                            </div>
                        }
                        else
                        {
                             <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Color="Color.Default" Class="mr-3" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Deposit not yet paid</MudText>
                            </div>
                        }
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter] public int TaskId { get; set; }
    private SkillTask? _task;
    private MapComponent? _miniMap;
    private int _currentUserId => UserState.CurrentUser?.Id ?? 0;
    
    private bool _isCreator => _task?.CreatorId == _currentUserId;
    private bool _isHelper => _task?.AssignedToId == _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        await LoadTask();
    }

    private async Task LoadTask()
    {
        _task = await TaskService.GetTaskByIdAsync(TaskId);
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _task != null && _miniMap != null && _task.Latitude.HasValue && _task.Longitude.HasValue)
        {
            await Task.Delay(500);
            await _miniMap.AddMarkerAsync(_task.Id, _task.Latitude.Value, _task.Longitude.Value, _task.Title, "task", _task.Category.ToString(), _task.IsUrgent || _task.Budget >= 100);
        }
    }

    // --- Core Interaction Logic ---

    private async Task OpenApplicationDialog()
    {
        if (!UserState.IsAuthenticated) 
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var parameters = new DialogParameters 
        { 
            ["TaskTitle"] = _task?.Title,
            ["Budget"] = _task?.Budget 
        };
        
        var dialog = await DialogService.ShowAsync<ApplyDialog>("Apply for Task", parameters);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is Tuple<decimal, string> data)
        {
            var price = data.Item1;
            var message = data.Item2;
            
            var success = await TaskService.ApplyForTaskAsync(TaskId, _currentUserId, price, message);
            if (success)
            {
                Snackbar.Add("Application submitted successfully!", Severity.Success);
                await LoadTask(); 
            }
            else
            {
                Snackbar.Add("Failed to submit application.", Severity.Error);
            }
        }
    }

    private async Task AcceptApplication(int applicationId)
    {
        var success = await TaskService.AcceptApplicationAsync(applicationId, _currentUserId);
        if (success)
        {
            var app = _task?.Applications.FirstOrDefault(a => a.Id == applicationId);
            var price = app?.ProposedPrice ?? _task?.Budget ?? 0;
            var deposit = price * 0.1m;
            
            var paySuccess = await WalletService.ProcessDepositAsync(_currentUserId, TaskId, deposit);
            
            if (paySuccess)
            {
                Snackbar.Add($"Application accepted & deposit (${deposit:F2}) paid!", Severity.Success);
            }
            else
            {
                Snackbar.Add("Application accepted, but deposit failed (insufficient funds?).", Severity.Warning);
            }
            
            await LoadTask();
        }
        else
        {
            Snackbar.Add("Failed to accept application.", Severity.Error);
        }
    }

    private async Task ConfirmTaskComplete()
    {
        if(_task == null) return;
        var success = await TaskService.CreatorConfirmTaskDoneAsync(_task.Id, _currentUserId);
        if (success) { Snackbar.Add("Confirmed!", Severity.Success); await LoadTask(); }
    }

    private async Task MarkTaskDone()
    {
        if(_task == null) return;
        var success = await TaskService.HelperMarkTaskDoneAsync(_task.Id, _currentUserId);
        if (success) { Snackbar.Add("Marked as done!", Severity.Success); await LoadTask(); }
    }
    
    private async Task CancelTask()
    {
        if(_task == null) return;
        var success = await TaskService.CancelTaskAsync(_task.Id);
        if (success) { Snackbar.Add("Cancelled.", Severity.Success); await LoadTask(); }
    }
    
    private async Task RepublishTask()
    {
        if(_task == null) return;
        var success = await TaskService.RepublishTaskAsync(_task.Id);
        if (success) { Snackbar.Add("Republished.", Severity.Success); await LoadTask(); }
    }

    private async Task ReportTask()
    {
        Snackbar.Add("Report submitted to admins.", Severity.Info);
        await Task.CompletedTask;
    }

    private async Task OpenRatingDialog()
    {
         if (_task == null || _task.AssignedToId == null) return;
        var parameters = new DialogParameters
        {
            ["TaskId"] = _task.Id,
            ["HelperId"] = _task.AssignedToId.Value,
            ["HelperName"] = _task.AssignedTo?.Username ?? "Helper",
            ["Category"] = _task.Category
        };
        var dialog = await DialogService.ShowAsync<SkillShareMap.Shared.Components.RatingDialog>("Rate Helper", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
    }
    
    private string GetCategoryName(TaskCategory category) => category.ToString();
    private Color GetStatusColor(SkillTaskStatus status) => status == SkillTaskStatus.Open ? Color.Success : Color.Default;
}