@namespace SkillShareMap.Shared.Components
@using SkillShareMap.Models

<MudIcon Icon="@SkillShareMap.Shared.SsmIcons.ForCategory(Category)" Color="@CategoryColor" Size="@IconSize" />

@code {
    [Parameter]
    public TaskCategory Category { get; set; }

    [Parameter]
    public Size IconSize { get; set; } = Size.Medium;

    [Parameter]
    public Color CategoryColor { get; set; } = Color.Primary;
}
