@inherits LayoutComponentBase

@namespace SkillShareMap.Shared
@inject NavigationManager Navigation
@inject SkillShareMap.Services.UserState UserState
@inject SkillShareMap.Services.IChatService ChatService

<MudPopoverProvider />
<MudThemeProvider Theme="AppTheme.Default" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* Top width *@
    <MudAppBar Elevation="0" Fixed="true" Class="px-12 pt-2" Style="height: 80px; background-color: #ffffff; color: #4a4a4a;">
        
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mr-8 cursor-pointer" onclick="location.href='/'">
            <MudImage Src="images/logo.png" Height="40" Alt="Logo" Class="mr-2"/>
        </MudStack>

        <MudStack Row="true" Spacing="8" AlignItems="AlignItems.Center" Class="d-none d-md-flex">
            
            <MudLink Href="/" Class="nav-hover-effect">Home</MudLink>
            
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mx-2">/</MudText>

            <MudLink Href="/classroom" Class="nav-hover-effect">Classroom</MudLink>

        </MudStack>

        <MudButton Variant="Variant.Filled" 
                   Href="/post-task"
                   Class="ml-12 px-8 py-2 rounded-pill post-task-btn"
                   DropShadow="false"
                   Style="background-color: #2b2b3d; color: white; text-transform: none; font-weight: 600; font-size: 16px;">
            Post a Task
        </MudButton>

        <MudSpacer />

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            
            <MudTooltip Text="Messages">
                <MudIconButton Icon="@Icons.Material.Outlined.ChatBubbleOutline" Color="Color.Secondary" Href="/chats" />
            </MudTooltip>

                 @if (UserState.IsAuthenticated)
                {
                    <MudMenu AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight"
                             PopoverClass="menu-paper-rounded"
                             ListClass="pa-0"
                             LockScroll="true">
        
                        <ActivatorContent>
                            <MudButton Variant="Variant.Text" 
                                       Class="rounded-circle d-flex justify-center align-center" 
                                       Style="width: 48px; height: 48px; min-width: 48px; padding: 0;">
        
                                <MudAvatar Color="Color.Primary" 
                                           Style="height: 32px; width: 32px; font-size: 14px;">
                                    @UserState.CurrentUser?.Username?.Substring(0, 1).ToUpper()
                                </MudAvatar>
        
                            </MudButton>
                        </ActivatorContent>

                        <ChildContent>
                            <div class="ssm-usermenu">
                                <div class="ssm-usermenu-head">
                                    <MudAvatar Color="Color.Primary" Class="ssm-usermenu-avatar">
                                        @UserState.CurrentUser?.Username?.Substring(0, 1).ToUpper()
                                    </MudAvatar>
                                    <div class="ssm-usermenu-id">
                                        <span class="ssm-usermenu-name">@UserState.CurrentUser?.Username</span>
                                        <span class="ssm-usermenu-email">@UserState.CurrentUser?.Email</span>
                                    </div>
                                </div>

                                <MudMenuItem Href="/profile" Class="ssm-usermenu-item" Icon="@Icons.Material.Outlined.Person">
                                    Profile Details
                                </MudMenuItem>

                                <MudMenuItem Href="/wallet" Class="ssm-usermenu-item" Icon="@Icons.Material.Outlined.AccountBalanceWallet">
                                    Wallet
                                </MudMenuItem>

                                <MudDivider Class="ssm-usermenu-divider" />

                                <MudMenuItem OnClick="HandleLogout" Class="ssm-usermenu-item ssm-usermenu-danger" Icon="@Icons.Material.Outlined.Logout">
                                    Sign Out
                                </MudMenuItem>
                            </div>
                        </ChildContent>
                    </MudMenu>
                }
                else
                {
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Inherit" 
                               Href="/login"
                               Style="text-transform: none; font-weight: 600;">
                        Log in
                    </MudButton>
                
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Inherit" 
                               Href="/register"
                               Class="rounded-pill px-4"
                               Style="text-transform: none; font-weight: 600; border-color: #333;">
                        Sign up
                    </MudButton>
                }
        </MudStack>

    </MudAppBar>

    <MudMainContent Class="pt-20">
        @Body
    </MudMainContent>

    @* Global AI command bar — single entry point, available on every page *@
    <SkillShareMap.Shared.Components.CommandBar />
</MudLayout>

<style>
    /* 1. New style specifically for 'home', 'AI Coach' and 'Classroom' */
    .nav-hover-effect {
        position: relative;
        color: #1B1B1B !important; /* Deep grey */
        text-decoration: none !important; /* no line */
        font-weight: 500;
        transition: color 0.3s;
        display: inline-block;
    }
    .nav-hover-effect::after {
        content: '';
        position: absolute;
        width: 0%;
        height: 2px; /* width */
        bottom: -10px; /* distance between texts and line */

        left: 50%;
        transform: translateX(-50%);
        
        background-color: #4a75b0; 
        transition: width 0.3s ease-in-out; /* animation effects */
    }

    /* Hover style */
    .nav-hover-effect:hover {
        /* color changed */
        color: #4a75b0 !important; 
    }
    .nav-hover-effect:hover::after {
        width: 130%; 
    }

    /* 2. New style specifically for the Post Task Button */
    .post-task-btn {
        transition: all 0.3s ease-in-out; /* Smooth transition animation */
    }

    .post-task-btn:hover {
        /* Change background to Blue-Grey */
        background-color: #4a75b0 !important; 
        
        /* Change text color to Black */
        color: #FFFFFF !important;
    }

    /* 3. Modern account dropdown */
    .menu-paper-rounded {
        border-radius: 18px !important;
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(20,30,50,0.18), 0 3px 10px rgba(20,30,50,0.08) !important;
        border: 1px solid rgba(20,30,50,0.06);
    }

    .ssm-usermenu { min-width: 252px; padding: 7px; }

    .ssm-usermenu-head {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 12px;
        margin-bottom: 5px;
        border-radius: 13px;
        background: linear-gradient(135deg, rgba(74,117,176,0.12), rgba(110,168,255,0.05));
    }
    .ssm-usermenu-avatar {
        height: 44px !important;
        width: 44px !important;
        font-size: 18px !important;
        font-weight: 600;
        box-shadow: 0 5px 14px rgba(74,117,176,0.4);
    }
    .ssm-usermenu-id { display: flex; flex-direction: column; min-width: 0; }
    .ssm-usermenu-name {
        font-weight: 700;
        font-size: 15px;
        color: #1B1B1B;
        line-height: 1.35;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 168px;
    }
    .ssm-usermenu-email {
        font-size: 12px;
        color: #8a96a8;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 168px;
    }

    .ssm-usermenu-item.mud-list-item {
        border-radius: 10px;
        padding: 9px 12px !important;
        margin: 2px 0;
        color: #33404f !important;
        font-weight: 500;
        font-size: 14px;
        transition: background-color 0.18s ease, color 0.18s ease;
    }
    .ssm-usermenu-item.mud-list-item:hover {
        background-color: rgba(74,117,176,0.10) !important;
        color: #4a75b0 !important;
    }
    .ssm-usermenu-item .mud-icon-root {
        font-size: 20px !important;
        margin-right: 12px !important;
        min-width: 20px !important;
        color: #8a96a8;
        transition: color 0.18s ease;
    }
    .ssm-usermenu-item:hover .mud-icon-root { color: #4a75b0; }

    .ssm-usermenu-danger.mud-list-item:hover {
        background-color: rgba(235,29,38,0.10) !important;
        color: #EB1D26 !important;
    }
    .ssm-usermenu-danger:hover .mud-icon-root { color: #EB1D26 !important; }

    .ssm-usermenu-divider { margin: 6px 4px !important; }

</style>


@code {
    private async Task HandleLogout()
    {
        await UserState.LogoutAsync();

        Navigation.NavigateTo("/", forceLoad: true);
    }
}